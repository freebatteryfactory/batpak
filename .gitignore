.claude/
.codex/
# Cargo build artifacts. The canonical Cargo output for this repo is
# `bpk-lib/target/`; repo-root and nested target dirs are cleanup-owned sprawl.
/target/
**/target/
# Keep bpk-lib/Cargo.lock tracked: this workspace includes binary developer
# tools, and release verification should use a reproducible dependency graph.
/.artifacts/
/.integrity-cache/
/.cache/
/guide/book/
*.profraw
*.log
/ci_output.txt
*.swp
*.swo
*~
.env
.env.local
.DS_Store
.idea/
.vscode/
.cursor/plans/
.cursor
# Nested Cargo.lock files from path-dependency fixture crates are cache, not
# source of truth.
bpk-lib/crates/core/fixtures/*/Cargo.lock
# Golden template crates are smoke-tested as standalone path-dependency apps;
# their generated lockfiles are local cache, not template source.
bpk-lib/templates/*/Cargo.lock
