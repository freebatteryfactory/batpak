# Keep the devcontainer build context small and prevent host build artifacts
# from leaking into the image. Container builds use CARGO_TARGET_DIR=/tmp/batpak-target
# (set in devcontainer.json), so target/ is host-only and must never cross.

target/
**/target/

# Git metadata is large and not needed inside the image.
.git/
.gitignore

# Host-specific coverage / bench / cache trees.
.artifacts/
.integrity-cache/
.cache/

# Editor / IDE / tool state.
.claude/
.codex/
.idea/
.vscode/
*.swp
*.swo

# Mutation-testing output.
mutants*/

# Local secrets.
.env
.env.local

# OS noise.
.DS_Store
